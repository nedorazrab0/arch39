#!/usr/bin/env bash
#
# iwctl alias
set -e

usage() {
  echo "usage: ${0##*/} [-h] -i INAME -n SSID"
  echo
  echo 'iwctl alias'
  echo
  echo 'options:'
  echo '  -h        show this help message and exit'
  echo '  -i INAME  set an interface name'
  echo '  -n SSID   set a SSID'
  exit "${1}"
}

main() {
  local OPTARG
  local arg

  if (($(id -u) != 0)); then
    echo '! Run this script as root'
    exit 1
  fi

  # Parse args
  ((${#} == 0)) && usage 1 >&2
  while getopts 'hi:n:' arg; do
    case "${arg}" in
      i) local iname="${OPTARG}" ;;
      n) local ssid="${OPTARG}" ;;
      h) usage 0 ;;
      *) usage 1 >&2 ;;
    esac
  done

  systemctl enable --now iwd
  iwctl station "${iname}" connect "${ssid}"
  # Remove the plain text passphrase
  sed -i '/^Passphrase=./d' "/var/lib/iwd/${ssid}.psk"
  systemctl restart systemd-networkd
}

main "${@}"
