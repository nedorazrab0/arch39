#!/usr/bin/env bash
#
# Run hyprland
set -e

usage() {
  echo "usage: ${0##*/} [-h]"
  echo
  echo 'run hyprland'
  echo
  echo 'options:'
  echo '  -h  show this help message and exit'
  exit "${1}"
}

main() {
  [[ "${@}" == '-h' ]] && usage 0
  ((${#} != 0)) && usage 1 >&2

  start-hyprland -- -c /etc/xdg/hypr/hyprland.lua
}

main "${@}"
    
